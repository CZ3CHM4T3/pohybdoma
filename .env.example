# Šablona proměnných prostředí pro POHYB DOMA.
# Zkopíruj tento soubor jako ".env.local" a doplň reálné hodnoty.
# .env.local se NEcommituje (je v .gitignore) – klíče zůstanou v bezpečí.

# ── Supabase ──
# Project URL a anon public klíč najdeš v Supabase: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role klíč je TAJNÝ – jen na serveru, nikdy v prohlížeči ani v gitu.
# Doplníme až bude potřeba (server-side admin operace).
SUPABASE_SERVICE_ROLE_KEY=

# ── Ecomail (newsletter) ──
# API klíč z Ecomail: Nastavení → Integrace → API. ID seznamu z URL seznamu.
# Tajné – jen na serveru.
ECOMAIL_API_KEY=
ECOMAIL_LIST_ID=
